# ~/.ssh/config — managed by dotfiles (deploy.sh)

# GitHub: use the dedicated key, offer ONLY that key, and cache it in the
# agent on first use so the passphrase is asked once per boot (see the
# ssh-agent.service systemd user unit + SSH_AUTH_SOCK in .zshrc).
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/github_ed25519
    IdentitiesOnly yes
    AddKeysToAgent yes
